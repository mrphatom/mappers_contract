# Anchor
.anchor
target
**/*.rs.bk
test-ledger

# Environment variables — NEVER commit these
.env
.env.local
.env.*
!.env.example

# Solana keypair files — never commit private keys
*-keypair.json
keypair.json
wallet.json

# Build outputs
oracle/dist/
apps/*/dist/
lib/*/dist/
scripts/dist/
*.tsbuildinfo

# Dependencies
node_modules

# OS
.DS_Store
Thumbs.db

# Package managers
.yarn
.pnp.*
pnpm-debug.log*

# Editor
.vscode/settings.json
.idea/
