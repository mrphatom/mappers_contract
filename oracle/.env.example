# ─── REQUIRED ──────────────────────────────────────────────────────────────────

# Solana JSON-RPC endpoint (use Helius for gRPC streaming support)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Deployed program ID — must match declare_id! in programs/project_mappers/src/lib.rs
PROGRAM_ID=52yt1gCbPeiKP4JYjUVKmMJSgBMMcUx8xRGqozMKX2Mu

# Oracle keypair — base58-encoded secret key (NEVER commit the real value)
ORACLE_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY_HERE

# ─── HELIUS gRPC ─────────────────────────────────────────────────────────────

# Helius Yellowstone gRPC endpoint (e.g. your-endpoint.helius-rpc.com:2053)
HELIUS_GRPC_ENDPOINT=YOUR_HELIUS_GRPC_ENDPOINT_HERE
HELIUS_API_KEY=YOUR_HELIUS_API_KEY_HERE

# ─── AI VERIFICATION ─────────────────────────────────────────────────────────

# Google Gemini API key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Anthropic Claude API key
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ─── OPTIONAL ──────────────────────────────────────────────────────────────────

# Gemini model name (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic model name (default: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Minimum confidence threshold for auto-approval 0–1 (default: 0.80)
# APPROVAL_CONFIDENCE_THRESHOLD=0.80

# Minimum confidence threshold for auto-rejection 0–1 (default: 0.75)
# REJECTION_CONFIDENCE_THRESHOLD=0.75

# Oracle HTTP server port (default: 3001)
# PORT=3001

# Shared API key the api-server must supply in X-Api-Key (leave empty in dev)
# ORACLE_API_KEY=a-strong-random-secret

# Sentry DSN for error tracking (leave empty to disable)
# SENTRY_DSN=

# Node environment — set to production to enforce fail-closed security guards
# NODE_ENV=production
