# ─── SOLANA ──────────────────────────────────────────────────────────────────
# RPC endpoint — use Helius for gRPC streaming support
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# The deployed program ID from Solana Playground / anchor deploy
PROGRAM_ID=YOUR_PROGRAM_ID_HERE

# Oracle keypair — base58 encoded private key
# This must match the `oracle` address stored in each GigEscrow account
ORACLE_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY_HERE

# ─── HELIUS gRPC ─────────────────────────────────────────────────────────────
# Helius gRPC endpoint (Yellowstone Geyser)
# Format: your-devnet-endpoint.helius-rpc.com:2053
HELIUS_GRPC_ENDPOINT=YOUR_HELIUS_GRPC_ENDPOINT
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# ─── AI VERIFICATION ─────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Model selection — override defaults if needed
GEMINI_MODEL=gemini-3.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-6

# Minimum confidence threshold for auto-approval (0.0 - 1.0)
APPROVAL_CONFIDENCE_THRESHOLD=0.80
REJECTION_CONFIDENCE_THRESHOLD=0.75

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── SECURITY ────────────────────────────────────────────────────────────────
# API key required for the /submit endpoint (leave blank to disable auth in dev)
ORACLE_API_KEY=

# CORS allowed origins (comma-separated). Empty = reject all cross-origin requests.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting — requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# ─── SENTRY ──────────────────────────────────────────────────────────────────
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
NODE_ENV=development
