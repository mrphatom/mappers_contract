# ─── BUILD-TIME ────────────────────────────────────────────────────────────────

# Base path if the dashboard is served at a sub-path (default: /)
# BASE_PATH=/

# ─── DEV SERVER ────────────────────────────────────────────────────────────────

# Vite dev-server port (default: 5173)
# PORT=5173

# ─── NOTES ─────────────────────────────────────────────────────────────────────
# The dashboard calls the API server using relative paths (/api/...) so no
# explicit API base URL is required — the Vite dev server (or your reverse proxy)
# must forward /api/* to the api-server origin.
#
# Wallet RPC: hardcoded to Solana devnet in src/components/wallet-provider.tsx.
# Update that file directly to change the cluster.
