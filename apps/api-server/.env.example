# ─── REQUIRED ──────────────────────────────────────────────────────────────────

# HTTP port the server listens on
PORT=3000

# PostgreSQL connection string (provisioned by Replit DB or self-hosted)
DATABASE_URL=postgresql://user:password@localhost:5432/mappers

# ─── OPTIONAL ──────────────────────────────────────────────────────────────────

# Oracle middleware base URL (default: http://localhost:3001)
# ORACLE_URL=http://localhost:3001

# Shared secret the oracle must use in X-Api-Key when calling this server
# Required in production (NODE_ENV != development)
# ORACLE_API_KEY=a-strong-random-secret

# Admin bearer key for privileged PATCH /jobs/:escrowPubkey calls
# Required in production (NODE_ENV != development)
# API_ADMIN_KEY=a-different-strong-secret

# Comma-separated list of allowed CORS origins
# (empty = reject all cross-origin requests)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-dashboard.replit.app

# Pino log level: trace | debug | info | warn | error | fatal (default: info)
# LOG_LEVEL=info

# Node environment — set to production to enforce fail-closed security guards
# NODE_ENV=production
